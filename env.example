# Auth mode
# AUTH_PROVIDER=acumatica (default) uses Acumatica direct auth endpoints.
# AUTH_PROVIDER=custom uses AUTH_LOGIN_URL/AUTH_ME_URL/AUTH_LOGOUT_URL.
AUTH_PROVIDER=acumatica
AUTH_LOGIN_URL=
AUTH_ME_URL=
AUTH_LOGOUT_URL=
AUTH_FORGOT_PASSWORD_URL=
AUTH_COOKIE_NAME=.ASPXAUTH
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
USER_CREDENTIALS_SECRET=
APP_BASE_URL=http://localhost:3000
STARTUP_WARMUP_ENABLED=true
STARTUP_WARMUP_MAX_ATTEMPTS=6
STARTUP_WARMUP_INITIAL_DELAY_MS=150
STARTUP_WARMUP_RETRY_DELAY_MS=750
STARTUP_WARMUP_REQUEST_TIMEOUT_MS=3000
# Defer in-process background cycles (watchdog/call-sync/coaching) right after boot.
RUNTIME_BACKGROUND_WORK_STARTUP_DEFER_MS=600000
# Memory-pressure guard for in-process background cycles (helps reduce exit-137 risk).
RUNTIME_MEMORY_PRESSURE_ENABLED=true
RUNTIME_MEMORY_PRESSURE_HEAP_USED_PERCENT_THRESHOLD=85
RUNTIME_MEMORY_PRESSURE_RSS_MB_THRESHOLD=450
RUNTIME_MEMORY_PRESSURE_CONSTRAINED_PERCENT_THRESHOLD=90
RUNTIME_MEMORY_PRESSURE_COOLDOWN_MS=180000

# Acumatica API
ACUMATICA_BASE_URL=https://meadowbrook.acumatica.com
ACUMATICA_ENTITY_PATH=/entity/lightspeed/24.200.001
ACUMATICA_COMPANY=MeadowBrook Live
ACUMATICA_BRANCH=
ACUMATICA_LOCALE=en-US
ACUMATICA_USERNAME=
ACUMATICA_PASSWORD=
ACUMATICA_SERVICE_USERNAME=
ACUMATICA_SERVICE_PASSWORD=
ACUMATICA_SERVICE_LOGOUT_AFTER_REQUEST=true
ACUMATICA_PHONE_CALL_ACTIVITY_TYPE=P
ACUMATICA_OPPORTUNITY_ENTITY=Opportunity
ACUMATICA_OPPORTUNITY_CLASS_DEFAULT=PRODUCTION
ACUMATICA_OPPORTUNITY_CLASS_SERVICE=SERVICE
ACUMATICA_OPPORTUNITY_CLASS_GLENDALE=GLENDALE
ACUMATICA_OPPORTUNITY_STAGE_DEFAULT=Awaiting Estimate
ACUMATICA_OPPORTUNITY_LOCATION_DEFAULT=MAIN
ACUMATICA_OPPORTUNITY_OWNER_DEFAULT=
ACUMATICA_OPPORTUNITY_ESTIMATION_OFFSET_DAYS=0
ACUMATICA_OPPORTUNITY_ATTR_WIN_JOB_ID=Do you think we are going to win this job?
ACUMATICA_OPPORTUNITY_ATTR_LINK_TO_DRIVE_ID=Link to Drive
ACUMATICA_OPPORTUNITY_ATTR_PROJECT_TYPE_ID=Project Type
ACUMATICA_OPPORTUNITY_LINK_TO_DRIVE_DEFAULT=
MAIL_SERVICE_URL=
MAIL_SERVICE_SHARED_SECRET=
MAIL_INTERNAL_DOMAIN=meadowb.com
MAIL_CONNECT_RETURN_PATH=/mail

# Customer onboarding automation
FIREBASE_PROJECT_ID=
ONBOARDING_TRIGGER_SECRET=
ONBOARDING_SCAN_LOOKBACK_HOURS=24
ONBOARDING_WON_STAGES=Won
ONBOARDING_WON_STATUSES=Won
ONBOARDING_DEFAULT_TERMS_ID=NET 30
ONBOARDING_CUSTOMER_PO_REQUIRED_FIELD=UsrPORequired
ONBOARDING_CUSTOMER_TERMS_FIELD=CreditTermsID
ONBOARDING_EMAIL_FROM=
ONBOARDING_EMAIL_REPLY_TO=
ONBOARDING_EMAIL_OVERRIDE_TO=jserrano@meadowb.com
ONBOARDING_EMAIL_BCC=
ONBOARDING_SMTP_HOST=
ONBOARDING_SMTP_PORT=587
ONBOARDING_SMTP_SECURE=false
ONBOARDING_SMTP_USER=
ONBOARDING_SMTP_PASS=

# Twilio Voice browser calling
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=replace-with-twilio-api-key-secret
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_CALLER_ID=
TWILIO_EDGE=ashburn
ROCKETREACH_API_KEY=replace-with-rocketreach-api-key
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SUMMARY_MODEL=gpt-4o-mini
CALL_ACTIVITY_BODY_MAX_CHARS=25000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Authorize ${APP_BASE_URL}/api/calendar/oauth/callback in Google Cloud OAuth redirect URIs.

# Canada Post AddressComplete (used for Canadian address edits)
ADDRESS_COMPLETE_API_KEY=AA11-AA11-AA11-AA11
ADDRESS_COMPLETE_FIND_URL=https://ws1.postescanada-canadapost.ca/AddressComplete/Interactive/Find/v2.10/json3.ws
ADDRESS_COMPLETE_RETRIEVE_URL=https://ws1.postescanada-canadapost.ca/AddressComplete/Interactive/Retrieve/v2.10/json3.ws

# Local read model
READ_MODEL_ENABLED=true
READ_MODEL_SQLITE_PATH=./data/read-model.sqlite
READ_MODEL_STATE_BACKEND=sqlite
DATA_QUALITY_HISTORY_PATH=./data/data-quality-history.json
DATA_QUALITY_HISTORY_BACKEND=file
SHARED_STATE_CUTOVER_ENABLED=false
# Shared backend DSN/path used when READ_MODEL_STATE_BACKEND=shared or
# DATA_QUALITY_HISTORY_BACKEND=shared and cutover is enabled.
# Supported formats: /absolute/path.sqlite, ./relative/path.sqlite, file://..., sqlite://...
SHARED_STATE_BACKEND_DSN=
READ_MODEL_STALE_AFTER_MS=300000
READ_MODEL_SYNC_INTERVAL_MS=900000
READ_MODEL_SYNC_STALE_RUNNING_AFTER_MS=1800000
READ_MODEL_ACTIVE_CALL_STALE_AFTER_MS=21600000
CALL_ANALYTICS_STALE_AFTER_MS=300000
CALL_EMPLOYEE_DIRECTORY_STALE_AFTER_MS=86400000
BUSINESS_ACCOUNTS_STREAM_MAX_GLOBAL=48
BUSINESS_ACCOUNTS_STREAM_MAX_PER_IP=4
BUSINESS_ACCOUNTS_STREAM_RETRY_AFTER_SECONDS=5
CALL_ACTIVITY_SYNC_ENABLED=true
CALL_ACTIVITY_SYNC_EXTERNAL_SCHEDULER_ENABLED=false
CALL_ACTIVITY_SYNC_SECRET=
CALL_ACTIVITY_SYNC_BATCH_SIZE=2
CALL_ACTIVITY_SYNC_SCHEDULE_HOUR=17
CALL_ACTIVITY_SYNC_SCHEDULE_MINUTE=0
CALL_ACTIVITY_SYNC_TIME_ZONE=America/Toronto
CALL_ACTIVITY_SYNC_MAX_BATCHES_PER_WINDOW=200
DAILY_CALL_COACHING_ENABLED=false
DAILY_CALL_COACHING_EXTERNAL_SCHEDULER_ENABLED=false
DAILY_CALL_COACHING_SECRET=
DAILY_CALL_COACHING_SENDER_LOGIN=jserrano
DAILY_CALL_COACHING_TIME_ZONE=America/Toronto
DAILY_CALL_COACHING_SCHEDULE_HOUR=7
DAILY_CALL_COACHING_SCHEDULE_MINUTE=0
DAILY_CALL_COACHING_LOOKBACK_DAYS=1
DAILY_CALL_COACHING_FORCE_MAIL_SERVICE=false

# Timeout-based production health-check SLO watchdog + paging
HEALTH_SLO_HEALTHCHECK_PATH=/api/healthz
HEALTH_SLO_SYNC_STATUS_PATH=/api/sync/status
HEALTH_SLO_RUNTIME_METRICS_PATH=/api/runtime/health-slo
HEALTH_SLO_TIMEOUT_MS=3000
HEALTH_SLO_PROBE_ATTEMPTS=3
HEALTH_SLO_CONSECUTIVE_TIMEOUTS=2
HEALTH_SLO_PROBE_PAUSE_MS=1000
HEALTH_SLO_ROUTE_P99_THRESHOLD_MS=3000
HEALTH_SLO_ROUTE_5XX_THRESHOLD_COUNT=1
HEALTH_SLO_EVENT_LOOP_P99_THRESHOLD_MS=750
HEALTH_SLO_EVENT_LOOP_MAX_THRESHOLD_MS=750
HEALTH_SLO_EVENT_LOOP_MAX_SPIKE_AGE_MS=360000
HEALTH_SLO_REQUIRE_RUNTIME_METRICS=false
HEALTH_SLO_RENDER_EVENT_LOOKBACK_MINUTES=30
HEALTH_SLO_RENDER_LOG_LOOKBACK_MINUTES=5
HEALTH_SLO_RENDER_LOG_LIMIT=500
HEALTH_SLO_RENDER_LOG_BURST_MIN_CRITICAL_ROUTES=3
HEALTH_SLO_RENDER_LOG_BURST_MIN_5XX=5
HEALTH_SLO_INCIDENT_PATH=CTO + DevOps & SRE Engineer incident path
HEALTH_SLO_PAGING_WEBHOOK_URL=
HEALTH_SLO_PAGING_WEBHOOK_TOKEN=
HEALTH_SLO_DRY_RUN=false
HEALTH_SLO_FORCE_INCIDENT=false
HEALTH_SLO_AUTO_DEPLOY_GUARD_ENABLED=true
HEALTH_SLO_AUTO_DEPLOY_UNLOCK_ON_HEALTHY=false
# Preferred watchdog control-plane credentials (falls back to RENDER_* if unset)
WATCHDOG_RENDER_SERVICE_ID=
WATCHDOG_RENDER_API_KEY=
# Legacy/shared Render control-plane credentials
RENDER_SERVICE_ID=
RENDER_API_KEY=

# Deploy cutover gate: transient-502 canary + promotion lock on critical-route 5xx
WATCHDOG_PROBE_PASSES=4
WATCHDOG_PROBE_PAUSE_MS=750
WATCHDOG_PROBE_TIMEOUT_MS=20000
WATCHDOG_PROBE_ERROR_BUDGET_COUNT=0
WATCHDOG_PROBE_FAIL_ON_BUDGET=true
WATCHDOG_PROBE_COLD_START_WINDOW_MS=120000
WATCHDOG_PROBE_PROMOTION_BLOCK_ON_5XX=true
WATCHDOG_PROBE_PROMOTION_BLOCK_DRY_RUN=false
# Optional dry-run helper: comma-separated endpoint names or paths (signin,healthz,sync_status,auth_session)
WATCHDOG_PROBE_SIMULATE_5XX_ENDPOINTS=
WATCHDOG_PROBE_OUTPUT_DIR=tmp

# Durable restart guardrail for Render dynamic-paid-error recurrence
GUARDRAIL_ENABLE_RESTART=true
GUARDRAIL_DRY_RUN=false
GUARDRAIL_AUTO_DEPLOY_LOCK_ENABLED=true
GUARDRAIL_AUTO_DEPLOY_LOCK_DRY_RUN=false
GUARDRAIL_PROBE_PASSES=3
GUARDRAIL_PROBE_PAUSE_MS=1000
GUARDRAIL_PROBE_TIMEOUT_MS=20000
GUARDRAIL_SUSTAINED_FAILURE_PASSES=2
GUARDRAIL_RESTART_WINDOW_MINUTES=45
GUARDRAIL_MAX_RESTARTS_PER_WINDOW=1
GUARDRAIL_RENDER_EVENT_LIMIT=100
GUARDRAIL_POST_RESTART_WAIT_MS=45000
GUARDRAIL_OUTPUT_DIR=tmp
